{
    "compilerOptions": {
        "target": "es2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": ["es2022", "DOM"],
        "allowJs": false,
        "declaration": true,
        "sourceMap": true,
        "inlineSources": true,
        "rootDir": "./src",
        "outDir": "./bin",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["**/*.spec.ts", "**/mock/*.ts"]
}
