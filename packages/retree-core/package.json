{
    "name": "@retreejs/core",
    "version": "0.7.1",
    "description": "React to changes in your object trees.",
    "author": "Ryan Bliss",
    "private": false,
    "type": "module",
    "license": "MIT",
    "main": "./bin/index.js",
    "types": "./bin/index.d.ts",
    "scripts": {
        "clean": "npx shx rm -rf bin",
        "build": "tsc -p tsconfig.json",
        "prepack": "node ../../scripts/sync-package-docs.mjs ."
    },
    "devDependencies": {
        "@types/assert": "^1.5.6",
        "@types/mocha": "^10.0.1",
        "@types/node": "^20.2.3",
        "@types/events": "^3.0.3",
        "nyc": "^15.1.0",
        "typescript": "^6.0.2"
    },
    "repository": {
        "directory": "packages/retree-core",
        "type": "git",
        "url": "git+https://github.com/ryanbliss/retree.git"
    },
    "homepage": "https://www.retree.dev/docs/quick-start",
    "bugs": {
        "url": "https://github.com/ryanbliss/retree/issues"
    },
    "exports": {
        ".": {
            "types": "./bin/index.d.ts",
            "default": "./bin/index.js"
        },
        "./internal": {
            "types": "./bin/internals/index.d.ts",
            "default": "./bin/internals/index.js"
        }
    },
    "files": [
        "bin",
        "llms.txt"
    ],
    "sideEffects": [
        "./bin/Retree.js"
    ]
}
