{
    "name": "@retreejs/react",
    "version": "0.5.1",
    "description": "Easily build stateful React applications using familiar JavaScript patterns.",
    "author": "Ryan Bliss",
    "license": "MIT",
    "private": false,
    "main": "./bin/index.js",
    "types": "./bin/index.d.ts",
    "scripts": {
        "clean": "node -e \"require('node:fs').rmSync('bin', { recursive: true, force: true })\"",
        "build": "npm run clean && tsc -p tsconfig.build.json",
        "typecheck": "tsc",
        "prepack": "node ../../scripts/sync-package-docs.mjs ."
    },
    "devDependencies": {
        "@babel/core": "^7.21.8",
        "@retreejs/core": "0.5.1",
        "@types/react": "^19.2.3",
        "@types/react-dom": "^19.2.3",
        "babel-loader": "^9.1.2",
        "typescript": "^6.0.2"
    },
    "peerDependencies": {
        "@retreejs/core": "0.5.1",
        "react": "^16.8.0 || ^17 || ^18 || ^19",
        "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    },
    "repository": {
        "directory": "packages/retree-core",
        "type": "git",
        "url": "https://github.com/ryanbliss/retree"
    },
    "homepage": "https://studiobliss.io",
    "bugs": {
        "url": "https://github.com/ryanbliss/retree/issues"
    },
    "exports": {
        ".": {
            "types": "./bin/index.d.ts",
            "default": "./bin/index.js"
        },
        "./internal": {
            "types": "./bin/internals/index.d.ts",
            "default": "./bin/internals/index.js"
        }
    },
    "files": [
        "bin",
        "llms.txt"
    ],
    "sideEffects": false
}
