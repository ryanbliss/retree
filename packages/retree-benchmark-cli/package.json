{
    "name": "@retreejs/benchmark-cli",
    "version": "0.6.0",
    "description": "Benchmark Retree listener emission performance across deterministic tree scenarios.",
    "author": "Ryan Bliss",
    "license": "MIT",
    "private": false,
    "type": "module",
    "bin": {
        "retree-benchmark": "./bin/cli.js"
    },
    "main": "./bin/index.js",
    "types": "./bin/index.d.ts",
    "scripts": {
        "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
        "benchmark": "npm run build && node ./bin/cli.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "prepack": "node ../../scripts/sync-package-docs.mjs ."
    },
    "dependencies": {
        "@inquirer/prompts": "^7.0.0",
        "@retreejs/core": "0.7.0",
        "@retreejs/react": "0.7.0",
        "jsdom": "^26.1.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@types/node": "^20.2.3",
        "typescript": "^6.0.2",
        "vite": "^8.0.0",
        "vitest": "^4.1.8"
    },
    "repository": {
        "directory": "packages/retree-benchmark-cli",
        "type": "git",
        "url": "git+https://github.com/ryanbliss/retree.git"
    },
    "homepage": "https://www.retree.dev",
    "bugs": {
        "url": "https://github.com/ryanbliss/retree/issues"
    },
    "exports": {
        ".": {
            "types": "./bin/index.d.ts",
            "default": "./bin/index.js"
        }
    },
    "files": [
        "bin",
        "README.md",
        "llms.txt"
    ]
}
